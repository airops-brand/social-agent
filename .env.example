SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret
SLACK_APP_TOKEN=xapp-your-app-token
NOTION_TOKEN=your-notion-integration-token
ANTHROPIC_API_KEY=your-anthropic-api-key

# Channels to watch (comma-separated, without #)
WATCH_CHANNELS=0-nuggets,social-workflow

# Channel-specific Notion pages (format: channel:pageId, comma-separated)
# Channels not listed here use the default Nuggets page
CHANNEL_NOTION_MAP=social-workflow:33b1f419db8a8032aed0f980166410d2

# Channel-specific voice/prompt (format: channel:promptKey, comma-separated)
# Available keys: "alex" (Alex Halliday), "airops" (AirOps brand)
# Channels not listed here default to "alex"
CHANNEL_PROMPT_MAP=social-workflow:airops

# Persistent state directory (must be a Railway volume mount)
STATE_DIR=/data

# Ordinal (social media scheduling)
ORDINAL_API_KEY=ord_...
ORDINAL_LINKEDIN_PROFILE_ID=a68df3c6-0870-45d0-adfc-a9b3d9917557

# Asana
ASANA_TOKEN=2/...
ASANA_PROJECT_ID=1212399031433417
